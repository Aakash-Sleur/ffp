diff --git a/occt-import-js/src/sheetmetal_analyze.cpp b/occt-import-js/src/sheetmetal_analyze.cpp
new file mode 100644
index 0000000..57197d5
--- /dev/null
+++ b/occt-import-js/src/sheetmetal_analyze.cpp
@@ -0,0 +1,207 @@
+#ifdef EMSCRIPTEN
+
+#include "sheetmetal_analyze.hpp"
+
+#include "importer-utils.hpp"
+
+#include <algorithm>
+#include <cctype>
+#include <cstdio>
+#include <fstream>
+#include <string>
+#include <vector>
+
+#include <BRep_Builder.hxx>
+#include <BRep_Tool.hxx>
+#include <BRepTools.hxx>
+#include <Geom_CylindricalSurface.hxx>
+#include <Geom_Plane.hxx>
+#include <IGESCAFControl_Reader.hxx>
+#include <STEPCAFControl_Reader.hxx>
+#include <TDF_LabelSequence.hxx>
+#include <TDocStd_Document.hxx>
+#include <TopExp_Explorer.hxx>
+#include <TopoDS.hxx>
+#include <TopoDS_Compound.hxx>
+#include <TopoDS_Face.hxx>
+#include <TopoDS_Shape.hxx>
+#include <XCAFDoc_DocumentTool.hxx>
+
+#include <emscripten/bind.h>
+
+static std::string GetLowerExt (const emscripten::val& opts)
+{
+    if (opts.isUndefined () || opts.isNull ()) {
+        return std::string ();
+    }
+    if (!opts.hasOwnProperty ("ext")) {
+        return std::string ();
+    }
+
+    std::string ext = opts["ext"].as<std::string> ();
+    std::transform (ext.begin (), ext.end (), ext.begin (), [] (unsigned char c) {
+        return static_cast<char> (std::tolower (c));
+    });
+    return ext;
+}
+
+static bool BuildShapeFromXcafDocument (const Handle (TDocStd_Document)& document, TopoDS_Shape& outShape)
+{
+    TDF_Label mainLabel = document->Main ();
+    Handle (XCAFDoc_ShapeTool) shapeTool = XCAFDoc_DocumentTool::ShapeTool (mainLabel);
+
+    TDF_LabelSequence freeShapeLabels;
+    shapeTool->GetFreeShapes (freeShapeLabels);
+    if (freeShapeLabels.IsEmpty ()) {
+        return false;
+    }
+
+    if (freeShapeLabels.Length () == 1) {
+        outShape = shapeTool->GetShape (freeShapeLabels.Value (1));
+        return !outShape.IsNull ();
+    }
+
+    BRep_Builder builder;
+    TopoDS_Compound compound;
+    builder.MakeCompound (compound);
+    for (Standard_Integer i = 1; i <= freeShapeLabels.Length (); i++) {
+        TopoDS_Shape freeShape = shapeTool->GetShape (freeShapeLabels.Value (i));
+        if (!freeShape.IsNull ()) {
+            builder.Add (compound, freeShape);
+        }
+    }
+
+    outShape = compound;
+    return !outShape.IsNull ();
+}
+
+static bool LoadStepShape (const std::vector<uint8_t>& fileContent, TopoDS_Shape& outShape)
+{
+    Handle (TDocStd_Document) document = new TDocStd_Document ("XmlXCAF");
+    XCAFDoc_DocumentTool::SetLengthUnit (document, 1.0, UnitsMethods_LengthUnit_Millimeter);
+
+    STEPCAFControl_Reader stepCafReader;
+    stepCafReader.SetColorMode (true);
+    stepCafReader.SetNameMode (true);
+
+    STEPControl_Reader& stepReader = stepCafReader.ChangeReader ();
+    std::string dummyFileName = "stp";
+    VectorBuffer inputBuffer (fileContent);
+    std::istream inputStream (&inputBuffer);
+    IFSelect_ReturnStatus readStatus = stepReader.ReadStream (dummyFileName.c_str (), inputStream);
+    if (readStatus != IFSelect_RetDone) {
+        return false;
+    }
+
+    if (!stepCafReader.Transfer (document)) {
+        return false;
+    }
+
+    return BuildShapeFromXcafDocument (document, outShape);
+}
+
+static bool LoadIgesShape (const std::vector<uint8_t>& fileContent, TopoDS_Shape& outShape)
+{
+    Handle (TDocStd_Document) document = new TDocStd_Document ("XmlXCAF");
+    XCAFDoc_DocumentTool::SetLengthUnit (document, 1.0, UnitsMethods_LengthUnit_Millimeter);
+
+    static int tempFileCounter = 0;
+    std::string tempFileName = "temp_sheetmetal_" + std::to_string (++tempFileCounter) + ".igs";
+
+    std::ofstream tempFile (tempFileName, std::ios::binary);
+    if (!tempFile.is_open ()) {
+        return false;
+    }
+    tempFile.write ((const char*) fileContent.data (), fileContent.size ());
+    tempFile.close ();
+
+    IGESCAFControl_Reader igesCafReader;
+    igesCafReader.SetColorMode (true);
+    igesCafReader.SetNameMode (true);
+
+    IFSelect_ReturnStatus readStatus = igesCafReader.ReadFile (tempFileName.c_str ());
+    if (readStatus != IFSelect_RetDone) {
+        std::remove (tempFileName.c_str ());
+        return false;
+    }
+
+    if (!igesCafReader.Transfer (document)) {
+        std::remove (tempFileName.c_str ());
+        return false;
+    }
+
+    std::remove (tempFileName.c_str ());
+    return BuildShapeFromXcafDocument (document, outShape);
+}
+
+static bool LoadBrepShape (const std::vector<uint8_t>& fileContent, TopoDS_Shape& outShape)
+{
+    VectorBuffer inputBuffer (fileContent);
+    std::istream inputStream (&inputBuffer);
+
+    BRep_Builder builder;
+    BRepTools::Read (outShape, inputStream, builder);
+    return !outShape.IsNull ();
+}
+
+static void CountShapeFeatures (const TopoDS_Shape& shape, int& solidCount, int& planarFaceCount, int& cylindricalFaceCount)
+{
+    solidCount = 0;
+    planarFaceCount = 0;
+    cylindricalFaceCount = 0;
+
+    for (TopExp_Explorer ex (shape, TopAbs_SOLID); ex.More (); ex.Next ()) {
+        solidCount += 1;
+    }
+
+    for (TopExp_Explorer ex (shape, TopAbs_FACE); ex.More (); ex.Next ()) {
+        const TopoDS_Face& face = TopoDS::Face (ex.Current ());
+        Handle (Geom_Surface) surface = BRep_Tool::Surface (face);
+        if (surface.IsNull ()) {
+            continue;
+        }
+
+        if (surface->IsKind (STANDARD_TYPE (Geom_Plane))) {
+            planarFaceCount += 1;
+        } else if (surface->IsKind (STANDARD_TYPE (Geom_CylindricalSurface))) {
+            cylindricalFaceCount += 1;
+        }
+    }
+}
+
+emscripten::val AnalyzeSheetMetal (const emscripten::val& fileBytes, const emscripten::val& opts)
+{
+    emscripten::val resultObj (emscripten::val::object ());
+    resultObj.set ("isAssembly", false);
+    resultObj.set ("isSheetMetal", false);
+    resultObj.set ("bendCount", 0);
+
+    std::vector<uint8_t> buffer = emscripten::vecFromJSArray<std::uint8_t> (fileBytes);
+    std::string ext = GetLowerExt (opts);
+
+    TopoDS_Shape shape;
+    bool loadSuccess = false;
+    if (ext == "step" || ext == "stp") {
+        loadSuccess = LoadStepShape (buffer, shape);
+    } else if (ext == "iges" || ext == "igs") {
+        loadSuccess = LoadIgesShape (buffer, shape);
+    } else if (ext == "brep") {
+        loadSuccess = LoadBrepShape (buffer, shape);
+    }
+
+    if (!loadSuccess || shape.IsNull ()) {
+        resultObj.set ("reason", "not_sheetmetal");
+        return resultObj;
+    }
+
+    int solidCount = 0;
+    int planarFaceCount = 0;
+    int cylindricalFaceCount = 0;
+    CountShapeFeatures (shape, solidCount, planarFaceCount, cylindricalFaceCount);
+
+    bool isAssembly = solidCount > 1;
+    bool isSheetMetal = !isAssembly && cylindricalFaceCount >= 1 && planarFaceCount >= 2;
+
+    resultObj.set ("isAssembly", isAssembly);
+    resultObj.set ("isSheetMetal", isSheetMetal);
+    resultObj.set ("bendCount", cylindricalFaceCount);
+
+    if (isAssembly) {
+        resultObj.set ("reason", "assembly");
+    } else if (!isSheetMetal) {
+        resultObj.set ("reason", "not_sheetmetal");
+    }
+
+    return resultObj;
+}
+
+#endif
