+
+static bool ResolveXcafShape (
+    const ImporterXcaf& importer,
+    const std::string& partId,
+    TopoDS_Shape& resolvedShape,
+    TDF_Label& resolvedLabel)
+{
+    if (partId.rfind ("xcf:", 0) != 0) {
+        return false;
+    }
+
+    std::string entry = partId.substr (4);
+    if (entry.empty () || entry == "root") {
+        return false;
+    }
+
+    const Handle (XCAFDoc_ShapeTool)& shapeTool = importer.GetShapeTool ();
+    if (shapeTool.IsNull ()) {
+        return false;
+    }
+
+    TDF_Label rootLabel = shapeTool->Label ();
+    TDF_Label targetLabel;
+    if (!FindLabelByEntryRecursive (rootLabel, entry, targetLabel)) {
+        return false;
+    }
+
+    TopoDS_Shape shape = shapeTool->GetShape (targetLabel);
+    if (shape.IsNull ()) {
+        return false;
+    }
+
+    resolvedShape = shape;
+    resolvedLabel = targetLabel;
+    return true;
+}
+
+static bool ParseIndexedPartId (const std::string& partId, const std::string& prefix, int& outIndex)
+{
+    if (partId.rfind (prefix, 0) != 0) {
+        return false;
+    }
+
+    std::string indexText = partId.substr (prefix.size ());
+    if (indexText.empty ()) {
+        return false;
+    }
+
+    char* endPtr = nullptr;
+    long parsed = std::strtol (indexText.c_str (), &endPtr, 10);
+    if (endPtr == nullptr || *endPtr != '\0') {
+        return false;
+    }
+    if (parsed < 0 || parsed > std::numeric_limits<int>::max ()) {
+        return false;
+    }
+
+    outIndex = static_cast<int> (parsed);
+    return true;
+}
+
+static bool ResolveBrepShapeByPartId (const TopoDS_Shape& rootShape, const std::string& partId, TopoDS_Shape& resolvedShape)
+{
+    if (partId == "brep:root") {
+        resolvedShape = rootShape;
+        return !resolvedShape.IsNull ();
+    }
+
+    int solidIndex = -1;
+    if (ParseIndexedPartId (partId, "brep:solid:", solidIndex)) {
+        int currentIndex = 0;
+        for (TopExp_Explorer ex (rootShape, TopAbs_SOLID); ex.More (); ex.Next ()) {
+            if (currentIndex == solidIndex) {
+                resolvedShape = ex.Current ();
+                return !resolvedShape.IsNull ();
+            }
+            currentIndex += 1;
+        }
+        return false;
+    }
+
+    int shellIndex = -1;
+    if (ParseIndexedPartId (partId, "brep:shell:", shellIndex)) {
+        int currentIndex = 0;
+        for (TopExp_Explorer ex (rootShape, TopAbs_SHELL, TopAbs_SOLID); ex.More (); ex.Next ()) {
+            if (currentIndex == shellIndex) {
+                resolvedShape = ex.Current ();
+                return !resolvedShape.IsNull ();
+            }
+            currentIndex += 1;
+        }
+        return false;
+    }
+
+    if (partId == "brep:faces:0") {
+        BRep_Builder builder;
+        TopoDS_Compound faceCompound;
+        builder.MakeCompound (faceCompound);
+
+        bool hasFace = false;
+        for (TopExp_Explorer ex (rootShape, TopAbs_FACE, TopAbs_SHELL); ex.More (); ex.Next ()) {
+            builder.Add (faceCompound, ex.Current ());
+            hasFace = true;
+        }
+
+        if (!hasFace) {
+            return false;
+        }
+
+        resolvedShape = faceCompound;
+        return !resolvedShape.IsNull ();
+    }
+
+    return false;
+}
+
+static bool ExportResolvedShape (
+    const std::string& outputFormat,
+    const TopoDS_Shape& resolvedShape,
+    const bool isXcafSource,
+    const TDF_Label& sourceLabel,
+    const Handle (XCAFDoc_ShapeTool)& sourceShapeTool,
+    const Handle (XCAFDoc_ColorTool)& sourceColorTool,
+    std::vector<uint8_t>& outBytes)
+{
+    if (outputFormat == "brep") {
+        return ExportShapeToBrep (resolvedShape, outBytes);
+    }
+
+    if (outputFormat == "step" || outputFormat == "stp") {
+        if (isXcafSource) {
+            return ExportXcafShapeToStep (
+                resolvedShape,
+                sourceLabel,
+                sourceShapeTool,
+                sourceColorTool,
+                outBytes);
+        }
+        return ExportShapeToStep (resolvedShape, outBytes);
+    }
+
+    if (outputFormat == "iges" || outputFormat == "igs") {
+        if (isXcafSource) {
+            return ExportXcafShapeToIges (
+                resolvedShape,
+                sourceLabel,
+                sourceShapeTool,
+                sourceColorTool,
+                outBytes);
+        }
+        return ExportShapeToIges (resolvedShape, outBytes);
+    }
+
+    return false;
+}
+
+static bool GetStringOpt (const emscripten::val& opts, const char* key, std::string& outValue)
+{
+    if (opts.isUndefined () || opts.isNull ()) {
+        return false;
+    }
+
+    if (!opts.hasOwnProperty (key)) {
+        return false;
+    }
+
+    emscripten::val field = opts[key];
+    if (field.isUndefined () || field.isNull ()) {
+        return false;
+    }
+
+    outValue = field.as<std::string> ();
+    return true;
+}
