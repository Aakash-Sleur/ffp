+static TDF_Label ResolveSourceLabel (const TDF_Label& sourceLabel, const Handle (XCAFDoc_ShapeTool)& shapeTool)
+{
+    if (!sourceLabel.IsNull () && XCAFDoc_ShapeTool::IsReference (sourceLabel)) {
+        TDF_Label referred;
+        shapeTool->GetReferredShape (sourceLabel, referred);
+        if (!referred.IsNull ()) {
+            return referred;
+        }
+    }
+    return sourceLabel;
+}
+
+static void CopyLabelName (const TDF_Label& sourceLabel, const TDF_Label& targetLabel)
+{
+    if (sourceLabel.IsNull () || targetLabel.IsNull ()) {
+        return;
+    }
+
+    Handle (TDataStd_Name) nameAttribute = new TDataStd_Name ();
+    if (sourceLabel.FindAttribute (nameAttribute->GetID (), nameAttribute)) {
+        TDataStd_Name::Set (targetLabel, nameAttribute->Get ());
+    }
+}
+
+static void CopyLabelColors (
+    const TDF_Label& sourceLabel,
+    const Handle (XCAFDoc_ColorTool)& sourceColorTool,
+    const TDF_Label& targetLabel,
+    const Handle (XCAFDoc_ColorTool)& targetColorTool)
+{
+    if (sourceLabel.IsNull () || targetLabel.IsNull () || sourceColorTool.IsNull () || targetColorTool.IsNull ()) {
+        return;
+    }
+
+    static const std::vector<XCAFDoc_ColorType> colorTypes = {
+        XCAFDoc_ColorSurf,
+        XCAFDoc_ColorCurv,
+        XCAFDoc_ColorGen
+    };
+
+    Quantity_Color qColor;
+    for (XCAFDoc_ColorType colorType : colorTypes) {
+        if (sourceColorTool->GetColor (sourceLabel, colorType, qColor)) {
+            targetColorTool->SetColor (targetLabel, qColor, colorType);
+        }
+    }
+}
+
+static bool ExportShapeToBrep (const TopoDS_Shape& shape, std::vector<uint8_t>& outBytes)
+{
+    std::string tempFileName = CreateTempFileName ("brep");
+    {
+        std::ofstream outputFile (tempFileName, std::ios::binary);
+        if (!outputFile.is_open ()) {
+            return false;
+        }
+        BRepTools::Write (shape, outputFile);
+        outputFile.close ();
+    }
+
+    bool readOk = ReadFileBytes (tempFileName, outBytes);
+    std::remove (tempFileName.c_str ());
+    return readOk;
+}
+
+static bool ExportShapeToStep (const TopoDS_Shape& shape, std::vector<uint8_t>& outBytes)
+{
+    STEPControl_Writer writer;
+    IFSelect_ReturnStatus transferStatus = writer.Transfer (shape, STEPControl_AsIs);
+    if (transferStatus != IFSelect_RetDone) {
+        return false;
+    }
+
+    std::string tempFileName = CreateTempFileName ("step");
+    IFSelect_ReturnStatus writeStatus = writer.Write (tempFileName.c_str ());
+    if (writeStatus != IFSelect_RetDone) {
+        std::remove (tempFileName.c_str ());
+        return false;
+    }
+
+    bool readOk = ReadFileBytes (tempFileName, outBytes);
+    std::remove (tempFileName.c_str ());
+    return readOk;
+}
