+}
+
+static std::string GetLabelEntry (const TDF_Label& label)
+{
+    TCollection_AsciiString asciiEntry;
+    TDF_Tool::Entry (label, asciiEntry);
+    if (asciiEntry.IsEmpty ()) {
+        return std::string ();
+    }
+    return std::string (asciiEntry.ToCString ());
+}
+
+static bool FindLabelByEntryRecursive (const TDF_Label& label, const std::string& entry, TDF_Label& found)
+{
+    if (GetLabelEntry (label) == entry) {
+        found = label;
+        return true;
+    }
+
+    for (TDF_ChildIterator it (label); it.More (); it.Next ()) {
+        TDF_Label child = it.Value ();
+        if (FindLabelByEntryRecursive (child, entry, found)) {
+            return true;
+        }
+    }
+
+    return false;
+}
