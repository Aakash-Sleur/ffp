+static bool ReadFileBytes (const std::string& filePath, std::vector<uint8_t>& outBytes)
+{
+    std::ifstream file (filePath, std::ios::binary);
+    if (!file.is_open ()) {
+        return false;
+    }
+
+    outBytes.assign (std::istreambuf_iterator<char> (file), {});
+    file.close ();
+    return true;
+}
