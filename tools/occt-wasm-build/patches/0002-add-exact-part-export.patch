+
+static bool ExportXcafShapeToStep (
+    const TopoDS_Shape& shape,
+    const TDF_Label& sourceLabel,
+    const Handle (XCAFDoc_ShapeTool)& sourceShapeTool,
+    const Handle (XCAFDoc_ColorTool)& sourceColorTool,
+    std::vector<uint8_t>& outBytes)
+{
+    Handle (TDocStd_Document) exportDocument = new TDocStd_Document ("XmlXCAF");
+    XCAFDoc_DocumentTool::SetLengthUnit (exportDocument, 1.0, UnitsMethods_LengthUnit_Millimeter);
+
+    TDF_Label exportMainLabel = exportDocument->Main ();
+    Handle (XCAFDoc_ShapeTool) exportShapeTool = XCAFDoc_DocumentTool::ShapeTool (exportMainLabel);
+    Handle (XCAFDoc_ColorTool) exportColorTool = XCAFDoc_DocumentTool::ColorTool (exportMainLabel);
+
+    TDF_Label exportShapeLabel = exportShapeTool->AddShape (shape, false);
+    TDF_Label sourceResolvedLabel = ResolveSourceLabel (sourceLabel, sourceShapeTool);
+    CopyLabelName (sourceResolvedLabel, exportShapeLabel);
+    CopyLabelColors (sourceResolvedLabel, sourceColorTool, exportShapeLabel, exportColorTool);
+
+    STEPCAFControl_Writer writer;
+    writer.SetColorMode (true);
+    writer.SetNameMode (true);
+
+    if (!writer.Transfer (exportDocument, STEPControl_AsIs)) {
+        return ExportShapeToStep (shape, outBytes);
+    }
+
+    std::string tempFileName = CreateTempFileName ("step");
+    IFSelect_ReturnStatus writeStatus = writer.Write (tempFileName.c_str ());
+    if (writeStatus != IFSelect_RetDone) {
+        std::remove (tempFileName.c_str ());
+        return ExportShapeToStep (shape, outBytes);
+    }
+
+    bool readOk = ReadFileBytes (tempFileName, outBytes);
+    std::remove (tempFileName.c_str ());
+    return readOk;
+}
