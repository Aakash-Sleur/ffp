+public:
+    XcafFace (const TopoDS_Face& face, const Handle (XCAFDoc_ShapeTool)& shapeTool, const Handle (XCAFDoc_ColorTool)& colorTool) :
+        OcctFace (face),
+        shapeTool (shapeTool),
+        colorTool (colorTool)
+    {
+
+    }
+
+    virtual bool GetColor (Color& color) const override
