+emscripten::val ExportPart (const emscripten::val& buffer, const emscripten::val& opts)
+{
+    emscripten::val resultObj (emscripten::val::object ());
+    resultObj.set ("success", false);
+
+    std::string inputExt;
+    std::string partId;
+    std::string outputFormat;
+    if (!GetStringOpt (opts, "inputExt", inputExt) ||
+        !GetStringOpt (opts, "partId", partId) ||
+        !GetStringOpt (opts, "format", outputFormat)) {
+        resultObj.set ("error", "Missing required export options");
+        return resultObj;
+    }
+
+    inputExt = ToLower (inputExt);
+    outputFormat = ToLower (outputFormat);
+
+    const std::vector<uint8_t>& fileContent = emscripten::vecFromJSArray<std::uint8_t> (buffer);
+    TopoDS_Shape resolvedShape;
+    TDF_Label sourceLabel;
+    bool isXcafSource = false;
+
+    Handle (XCAFDoc_ShapeTool) sourceShapeTool;
+    Handle (XCAFDoc_ColorTool) sourceColorTool;
+
+    ImportParams importParams;
+    if (inputExt == "step" || inputExt == "stp" || inputExt == "iges" || inputExt == "igs") {
+        std::shared_ptr<ImporterXcaf> importer;
+        if (inputExt == "step" || inputExt == "stp") {
+            importer = std::make_shared<ImporterStep> ();
+        } else {
+            importer = std::make_shared<ImporterIges> ();
+        }
+
+        Importer::Result importResult = importer->LoadFile (fileContent, importParams);
+        if (importResult != Importer::Result::Success) {
+            resultObj.set ("error", "Failed to load source CAD file");
+            return resultObj;
+        }
+
+        if (!ResolveXcafShape (*importer, partId, resolvedShape, sourceLabel)) {
+            resultObj.set ("error", "Failed to resolve CAD part by partId");
+            return resultObj;
+        }
+
+        isXcafSource = true;
+        sourceShapeTool = importer->GetShapeTool ();
+        sourceColorTool = importer->GetColorTool ();
+    } else if (inputExt == "brep") {
+        ImporterBrep importer;
+        Importer::Result importResult = importer.LoadFile (fileContent, importParams);
+        if (importResult != Importer::Result::Success) {
+            resultObj.set ("error", "Failed to load source CAD file");
+            return resultObj;
+        }
+
+        if (!ResolveBrepShapeByPartId (importer.GetShape (), partId, resolvedShape)) {
+            resultObj.set ("error", "Failed to resolve CAD part by partId");
+            return resultObj;
+        }
+    } else {
+        resultObj.set ("error", "Unsupported source extension");
+        return resultObj;
+    }
+
+    if (resolvedShape.IsNull ()) {
+        resultObj.set ("error", "Resolved CAD shape is null");
+        return resultObj;
+    }
+
+    std::vector<uint8_t> exportedBytes;
+    if (!ExportResolvedShape (
+        outputFormat,
+        resolvedShape,
+        isXcafSource,
+        sourceLabel,
+        sourceShapeTool,
+        sourceColorTool,
+        exportedBytes)) {
+        resultObj.set ("error", "Failed to export exact CAD shape");
+        return resultObj;
+    }
+
+    emscripten::val byteArray = emscripten::val::global ("Uint8Array").new_ (
+        emscripten::typed_memory_view (exportedBytes.size (), exportedBytes.data ())
+    );
+
+    resultObj.set ("success", true);
+    resultObj.set ("format", outputFormat);
+    resultObj.set ("bytes", byteArray);
+    return resultObj;
+}
